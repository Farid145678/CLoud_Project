# Copy to .env for local development

SECRET_KEY=dev-secret-change-me-please

# ── Database ───────────────────────────────────────────────────────────────
# Local: SQLite. AWS: RDS PostgreSQL via RDS Proxy
DATABASE_URL=sqlite:///shopcloud.db
# DATABASE_URL=postgresql+psycopg2://shopclouduser:pass@PROXY_ENDPOINT:5432/shopcloud

# ── Storage ────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./local_storage
S3_BUCKET=
AWS_REGION=eu-west-1
CLOUDFRONT_DOMAIN=

# ── ElastiCache Redis (cart caching) ───────────────────────────────────────
REDIS_HOST=
REDIS_PORT=6379

# ── DynamoDB (shopping cart) ───────────────────────────────────────────────
DYNAMODB_CART_TABLE=shopcloud-cart

# ── SNS (order events + seller notifications) ──────────────────────────────
SNS_ORDER_TOPIC_ARN=

# ── SQS (order processing queue) ───────────────────────────────────────────
SQS_ORDER_QUEUE_URL=

# ── SES (transactional emails) ─────────────────────────────────────────────
SES_SENDER_EMAIL=noreply@yourdomain.com

# ── App ────────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:5000
ADMIN_EMAIL=admin@shopcloud.com
ADMIN_PASSWORD=admin123
